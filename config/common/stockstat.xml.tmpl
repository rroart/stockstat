<config>
  <!-- core and icore -->
  <database>
    <spark enable='$SPARKDB'>
      <sparkmaster>$SPARKMASTER</sparkmaster>
    </spark>
    <hibernate enable='$HIBERNATE'/>
    <spring enable='$SPRING'/>
    <maxholes>0</maxholes>
    <batchsize>$DBBATCHSIZE</batchsize>
  </database>
  <misc>
    <!-- core -->
    <percentizepriceindex enable='true'/>
    <mlstats enable='true'/>
    <otherstats enable='true'/>
    <mydays>180</mydays>
    <mytopbottom>10</mytopbottom>
    <mytabledays>180</mytabledays>
    <mytablemoveintervaldays>5</mytablemoveintervaldays>
    <mytableintervaldays>1</mytableintervaldays>
    <myequalize enable='true'/>
    <mygraphequalize enable='true'/>
    <mygraphequalizeunify enable='true'/>
    <!-- machinelearning -->
    <threshold>$THRESHOLD</threshold>
    <!--threshold>[ 0.90, 0.95, 1.0, 1.05, 1.10 ]</threshold-->
    <!-- icore -->
    <shutdownhour>$SHUTDOWNHOUR</shutdownhour>
    <populate enable="$POPULATE"/>
    <abnormalchange>$ABNORMALCHANGE</abnormalchange>

    <!-- common -->
    <cache enable='$CACHE'>
      <ttl>$CACHETTL</ttl>
    </cache>
    <zookeeper>$ZOOKEEPER</zookeeper>
    <!-- todo fix -->
    <inmemory><server>$INMEMORYSERVER</server></inmemory>
    <inmemory><redis>$INMEMORYREDIS</redis></inmemory>
    <inmemory>
    <pipeline enable="$INMEMORYPIPELINE">
    <batchsize>$PIPELINEBATCHSIZE</batchsize>
    </pipeline>
    </inmemory>
    <myservices>$MYSERVICES</myservices>
    <services>$SERVICES</services>
    <servicerest enable="$SERVICEREST"/>
    <communications>$COMMUNICATIONS</communications>
  </misc>

  <!-- machinelearning -->
  <machinelearning enable='$MACHINELEARNING'>
    <mp enable='true'>
      <cpu>0.5</cpu>
    </mp>
    <sparkml enable='$SPARK'>
      <sparkmaster>$SPARKMASTER</sparkmaster>
      <sparknetworktimeout>600</sparknetworktimeout>
      <mlpc enable='true'/>
      <lor enable='true'/>
      <ovr enable='true'/>
      <lsvc enable='true'/>
      <path>$SPARKPATH</path>
    </sparkml>
    <tensorflow enable='$TENSORFLOW'>
      <dnn enable='true'/>
      <lic enable='true'/>
      <mlp enable='true'/>
      <cnn enable='true'/>
      <cnn2 enable='true'/>
      <rnn enable='true'/>
      <gru enable='true'/>
      <lstm enable='true'/>
      <!--server>http://prevfree:8008</server-->
      <path>$TENSORFLOWPATH</path>
      <server>$TENSORFLOWSERVER</server>
    </tensorflow>
    <pytorch enable='$PYTORCH'>
      <mlp enable='true'/>
      <cnn enable='true'/>
      <cnn2 enable='true'/>
      <rnn enable='true'/>
      <gru enable='true'/>
      <lstm enable='true'/>
      <path>$PYTORCHPATH</path>
      <server>$PYTORCHSERVER</server>
    </pytorch>
    <gem enable='$GEM'>
      <ewc enable='true'/>
      <gem enable='true'/>
      <icarl enable='false'/>
      <independent enable='true'/>
      <multimodal enable='true'/>
      <single enable='true'/>
      <path>$GEMPATH</path>
      <server>$GEMSERVER</server>
    </gem>
    <predictors enable='$PREDICTORS'>
      <tensorflow enable='true'>
	<lir enable='true'/>
	<mlp enable='true'/>
	<rnn enable='true'/>
	<lstm enable='true'/>
	<gru enable='true'/>
      </tensorflow>
      <pytorch enable='true'>
	<mlp enable='true'/>
	<rnn enable='true'/>
	<lstm enable='true'/>
	<gru enable='true'/>
      </pytorch>
    </predictors>
    <mldynamic enable='false'/>
    <usebinary enable='true'/>
  </machinelearning>

  <!-- core -->
  <indicators enable='true'>
    <move enable='true'/>
    <macd enable='true'>
      <macdhistogramdelta enable='true'/>
      <macdhistogramdeltadays>3</macdhistogramdeltadays>
      <macdmacddelta enable='true'/>
      <macdmacddeltadays>3</macdmacddeltadays>
      <macdsignaldelta enable='true'/>
      <macdsignaldeltadays>3</macdsignaldeltadays>
      <recommend enable='true'>
	<buy>
	<weighthistogram>55</weighthistogram>
	<weighthistogramdelta>15</weighthistogramdelta>
	<weightmacd>15</weightmacd>
	<weightmacddelta>15</weightmacddelta>
	</buy>
	<sell>
	<weighthistogram>15</weighthistogram>
	<weighthistogramdelta>25</weighthistogramdelta>
	<weightmacd>15</weightmacd>
	<weightmacddelta>45</weightmacddelta>
	</sell>
      </recommend>
    </macd>
    <rsi enable='true'>
      <rsidelta enable='true'/>
      <rsideltadays>3</rsideltadays>
      <recommend enable='true'>
	<buy>
	<weight>55</weight>
	<weightdelta>55</weightdelta>
	</buy>
	<sell>
	<weight>55</weight>
	<weightdelta>55</weightdelta>
	</sell>
      </recommend>
    </rsi>
    <stochrsi enable='true'>
      <stochrsidelta enable='true'/>
      <stochrsideltadays>3</stochrsideltadays>
    </stochrsi>
    <cci enable='true'>
      <ccidelta enable='true'/>
      <ccideltadays>3</ccideltadays>
    </cci>
    <atr enable='true'>
      <atrdelta enable='true'/>
      <atrdeltadays>3</atrdeltadays>
    </atr>
    <stoch enable='true'>
      <stochdelta enable='true'/>
      <stochdeltadays>3</stochdeltadays>
    </stoch>
  </indicators>
  <evolution>
    <indicatorrecommender>
      <evolutionconfig>{ "generations" : 100, "crossover" : 2, "elite" : 1, "elitecloneandmutate" : 1, "select" : 16, "mutate" : 2, "generationcreate" : 1, "useoldelite" : true }</evolutionconfig>
      <simple>
	<futuredays>10</futuredays>
	<intervaldays>5</intervaldays>
      </simple>
      <complex>
	<futuredays>10</futuredays>
	<intervaldays>5</intervaldays>
      </complex>
      <!--intervaltimes>10</intervaltimes>
      <iterations>100</iterations>
      <period>Price</period-->
    </indicatorrecommender>
    <save>
	<location>$SAVELOCATION</location>
	<path>$SAVEPATH</path>
    </save>
  </evolution>

  <!-- machinelearning -->
  <evolve>
    <ml>
      <evolutionconfig>{ "generations" : 10, "crossover" : 2, "elite" : 1, "elitecloneandmutate" : 1, "select" : 16, "mutate" : 2, "generationcreate" : 1, "useoldelite" : true }</evolutionconfig>
      <!--evolutionconfig>{ "generations" : 0, "crossover" : 2, "elite" : 1, "elitecloneandmutate" : 1, "select" : 4, "mutate" : 2, "generationcreate" : 1, "useoldelite" : true }</evolutionconfig-->
    </ml>
    <save>
	<location>$SAVELOCATION</location>
	<path>$SAVEPATH</path>
    </save>
  </evolve>
  <aggregators enable='true'>
    <indicatorrecommender enable='true'>
      <simple enable='true'>
	<macd enable='true'>
	  <buy>
	  <weighthistogram>50</weighthistogram>
	  <weighthistogramdelta>10</weighthistogramdelta>
	  <weightmacd>10</weightmacd>
	  <weightmacddelta>10</weightmacddelta>
	  <weightsignal>10</weightsignal>
	  <weightsignaldelta>10</weightsignaldelta>
	  </buy>
	  <sell>
	  <weighthistogram>50</weighthistogram>
	  <weighthistogramdelta>10</weighthistogramdelta>
	  <weightmacd>10</weightmacd>
	  <weightmacddelta>10</weightmacddelta>
	  <weightsignal>10</weightsignal>
	  <weightsignaldelta>10</weightsignaldelta>
	  </sell>
	</macd>
	<rsi enable='true'>
	  <buy>
	  <weightrsi>20</weightrsi>
	  <weightrsidelta>20</weightrsidelta>
	  </buy>
	  <sell>
	  <weightrsi>20</weightrsi>
	  <weightrsidelta>20</weightrsidelta>
	  </sell>
	</rsi>
      </simple>
      <complex enable='true'>
	<macd enable='true'>
	  <buy>
	  <weighthistogramnode></weighthistogramnode>
	  <weighthistogramdeltanode></weighthistogramdeltanode>
	  <weightmacdnode></weightmacdnode>
	  <weightmacddeltanode></weightmacddeltanode>
	  <weightsignalnode></weightsignalnode>
	  <weightsignaldeltanode></weightsignaldeltanode>
	  </buy>
	  <sell>
	  <weighthistogramnode></weighthistogramnode>
	  <weighthistogramdeltanode></weighthistogramdeltanode>
	  <weightmacdnode></weightmacdnode>
	  <weightmacddeltanode></weightmacddeltanode>
	  <weightsignalnode></weightsignalnode>
	  <weightsignaldeltanode></weightsignaldeltanode>
	  </sell>
	</macd>
	<rsi enable='true'>
	  <buy>
	  <weightrsinode></weightrsinode>
	  <weightrsideltanode></weightrsideltanode>
	  </buy>
	  <sell>
	  <weightrsinode></weightrsinode>
	  <weightrsideltanode></weightrsideltanode>
	  </sell>
	</rsi>
	<atr enable='true'>
	  <buy>
	  <weightatrnode></weightatrnode>
	  <weightatrdeltanode></weightatrdeltanode>
	  </buy>
	  <sell>
	  <weightatrnode></weightatrnode>
	  <weightatrdeltanode></weightatrdeltanode>
	  </sell>
	</atr>
	<cci enable='true'>
	  <buy>
	  <weightccinode></weightccinode>
	  <weightccideltanode></weightccideltanode>
	  </buy>
	  <sell>
	  <weightccinode></weightccinode>
	  <weightccideltanode></weightccideltanode>
	  </sell>
	</cci>
	<stoch enable='true'>
	  <buy>
	  <weightstochnode></weightstochnode>
	  <weightstochdeltanode></weightstochdeltanode>
	  </buy>
	  <sell>
	  <weightstochnode></weightstochnode>
	  <weightstochdeltanode></weightstochdeltanode>
	  </sell>
	</stoch>
	<stochrsi enable='true'>
	  <buy>
	  <weightstochrsinode></weightstochrsinode>
	  <weightstochrsideltanode></weightstochrsideltanode>
	  </buy>
	  <sell>
	  <weightstochrsinode></weightstochrsinode>
	  <weightstochrsideltanode></weightstochrsideltanode>
	  </sell>
	</stochrsi>
      </complex>
    </indicatorrecommender>
    <indicator enable='true'>
      <macd enable='true'/>
      <rsi enable='true'/>
      <atr enable='true'/>
      <cci enable='true'/>
      <stoch enable='true'/>
      <stochrsi enable='true'/>
      <extras>$EXTRAS</extras>
      <extrasdeltas>3</extrasdeltas>
      <extrasmacd enable='true'/>
      <extrasrsi enable='true'/>
      <extrasatr enable='true'/>
      <extrascci enable='true'/>
      <extrasstoch enable='true'/>
      <extrasstochrsi enable='true'/>
      <intervaldays>20</intervaldays>
      <futuredays>10</futuredays>
    </indicator>
    <mlmacd enable='true'>
      <macdml enable='true'/>
      <histogramml enable='true'/>
      <signalml enable='true'/>
      <daysbeforezero>25</daysbeforezero>
      <daysafterzero>10</daysafterzero>
    </mlmacd>
    <mlrsi enable='true'>
      <buy>
	<rsilimit>20</rsilimit>
	<srsilimit>0.2</srsilimit>
      </buy>
      <sell>
	<rsilimit>80</rsilimit>
	<srsilimit>0.8</srsilimit>
      </sell>
      <daysbeforelimit>25</daysbeforelimit>
      <daysafterlimit>10</daysafterlimit>
    </mlrsi>
    <mlatr enable='true'>
      <buylimit>2</buylimit>
      <selllimit>2</selllimit>
      <daysbeforelimit>25</daysbeforelimit>
      <daysafterlimit>10</daysafterlimit>
    </mlatr>
    <mlcci enable='true'>
      <buylimit>-80</buylimit>
      <selllimit>80</selllimit>
      <daysbeforelimit>25</daysbeforelimit>
      <daysafterlimit>10</daysafterlimit>
    </mlcci>
    <mlstoch enable='true'>
      <buylimit>20</buylimit>
      <selllimit>80</selllimit>
      <daysbeforelimit>25</daysbeforelimit>
      <daysafterlimit>10</daysafterlimit>
    </mlstoch>
    <mlmulti enable='true'>
      <macd enable='true'/>
      <rsi enable='true'/>
      <atr enable='true'/>
      <cci enable='true'/>
      <stoch enable='true'/>
      <stochrsi enable='true'/>
      <daysbeforelimit>25</daysbeforelimit>
      <daysafterlimit>10</daysafterlimit>
    </mlmulti>
    <minimumsize>$MINSIZE</minimumsize>
    <usecurve enable='false'/>
    <useconfusion enable='false'/>
  </aggregators>

  <!-- local only? -->
  <filesystem>
    <hdfs enable="$HDFS">
      <hdfsconffs>$HDFSCONFFS</hdfsconffs>
    </hdfs>
    <swift enable="$SWIFT">
      <swiftconfurl>$SWIFTCONFURL</swiftconfurl>
      <swiftconfuser>$SWIFTCONFUSER</swiftconfuser>
      <swiftconfkey>$SWIFTCONFKEY</swiftconfkey>
      <swiftconfcontainer>$SWIFTCONFCONTAINER</swiftconfcontainer>
    </swift>
    <s3 enable="$S3">
	<host>$S3HOST</host>
	<port>$S3PORT</port>
	<region>$S3REGION</region>
	<accesskey>$S3ACCESSKEY</accesskey>
	<secretkey>$S3SECRETKEY</secretkey>
    </s3>
  </filesystem>

  <!-- icore -->
  <mp>
    <server>
      <cpu>0.5</cpu>
    </server>
    <client>
      <cpu>0.5</cpu>
    </client>
  </mp>
  <iclij>
  <schedule enable='$SCHEDULE'/>
  </iclij>
  <evolve priority="50">
    <indicatorrecommender enable='true'>
      <evolutionconfig>{ "generations" : 100, "crossover" : 2, "elite" : 1, "elitecloneandmutate" : 0, "select" : 16, "mutate" : 2, "generationcreate" : 1, "useoldelite" : true, "shutdownhour" : $SHUTDOWNHOUR }</evolutionconfig>
    </indicatorrecommender>
    <ml enable='true'>
      <evolutionconfig>{ "generations" : 1, "crossover" : 2, "elite" : 1, "elitecloneandmutate" : 0, "select" : 16, "mutate" : 2, "generationcreate" : 1, "useoldelite" : true, "shutdownhour" : $SHUTDOWNHOUR }</evolutionconfig>
      <mlconfig>{ "spark" : { "mlpc" : { "load" : true, "save" : true, "enable" : $SPARK, "evolve" : true }, "lor" : { "load" : true, "save" : true, "enable" : $SPARK, "evolve" : true }, "ovr" : { "load" : true, "save" : true, "enable" : $SPARK, "evolve" : true }, "lsvc" : { "load" : true, "save" : true, "enable" : $SPARK, "evolve" : true } }, "tensorflow" : { "dnn" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true },  "lic" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true }, "lir" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true }, "mlp" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true }, "cnn" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true }, "cnn2" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true }, "rnn" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true }, "lstm" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true }, "gru" : { "load" : true, "save" : true, "enable" : $TENSORFLOW, "evolve" : true } }, "pytorch" : { "mlp" : { "load" : true, "save" : true, "enable" : $PYTORCH, "evolve" : true }, "cnn" : { "load" : true, "save" : true, "enable" : $PYTORCH, "evolve" : true }, "cnn2" : { "load" : true, "save" : true, "enable" : $PYTORCH, "evolve" : true }, "rnn" : { "load" : true, "save" : true, "enable" : $PYTORCH, "evolve" : true }, "lstm" : { "load" : true, "save" : true, "enable" : $PYTORCH, "evolve" : true }, "gru" : { "load" : true, "save" : true, "enable" : $PYTORCH, "evolve" : true } }, "gem" : { "ewc" : { "load" : true, "save" : true, "enable" : $GEM, "evolve" : true }, "gem" : { "load" : true, "save" : true, "enable" : $GEM, "evolve" : true }, "i" : { "load" : true, "save" : true, "enable" : $GEM, "evolve" : true }, "icarl" : { "load" : true, "save" : true, "enable" : false, "evolve" : true }, "mm" : { "load" : true, "save" : true, "enable" : $GEM, "evolve" : true }, "s" : { "load" : true, "save" : true, "enable" : $GEM, "evolve" : true } } }</mlconfig>
    </ml>
    <predictor enable='false'>
    </predictor>
    <autorun enable="$EVOLVE"/>
    <update enable='$EVOLVEUPDATE'/>
  </evolve>
  <findprofit priority="10">
    <threshold>$THRESHOLD</threshold>
    <futuredays>$FUTUREDAYS</futuredays>
    <autorun enable="$FINDPROFIT"/>
    <update enable='$FINDPROFITUPDATE'/>
    <mldynamic enable='false'/>
    <recommender enable='false'/>
    <mlmacd enable='true'>
    </mlmacd>
    <mlrsi enable='true'>
    </mlrsi>
    <mlatr enable='true'>
    </mlatr>
    <mlcci enable='true'>
    </mlcci>
    <mlstoch enable='true'>
    </mlstoch>
    <mlmulti enable='true'>
    </mlmulti>
    <mlindicator enable='true'>
    </mlindicator>
    <predictor enable='true'>
      <evolutionconfig>{ "generations" : 1, "crossover" : 2, "elite" : 1, "elitecloneandmutate" : 0, "select" : 4, "mutate" : 2, "generationcreate" : 1, "useoldelite" : true }</evolutionconfig>
    </predictor>
  </findprofit>
  <improveprofit priority="60">
    <autorun enable="$IMPROVEPROFIT"/>
    <update enable='$IMPROVEPROFITUPDATE'/>
    <recommender enable='true'/>
    <mlmacd enable='true'>
    </mlmacd>
    <mlrsi enable='true'>
    </mlrsi>
    <mlatr enable='true'>
    </mlatr>
    <mlcci enable='true'>
    </mlcci>
    <mlstoch enable='true'>
    </mlstoch>
    <mlmulti enable='true'>
    </mlmulti>
    <mlindicator enable='true'>
    </mlindicator>
    <predictor enable='false'>
    </predictor>
  </improveprofit>
  <improvefilter priority="30">
    <autorun enable="$IMPROVEFILTER"/>
    <recommender enable='true'/>
    <mlmacd enable='true'>
    </mlmacd>
    <mlrsi enable='true'>
    </mlrsi>
    <mlatr enable='true'>
    </mlatr>
    <mlcci enable='true'>
    </mlcci>
    <mlstoch enable='true'>
    </mlstoch>
    <mlmulti enable='true'>
    </mlmulti>
    <mlindicator enable='true'>
    </mlindicator>
    <predictor enable='false'>
    </predictor>
  </improvefilter>
  <improveabovebelow priority="20">
    <autorun enable="$IMPROVEABOVEBELOW"/>
    <evolutionconfig>{ "generations" : 100, "crossover" : 2, "elite" : 1, "elitecloneandmutate" : 0, "select" : 32, "mutate" : 2, "generationcreate" : 1, "useoldelite" : true }</evolutionconfig>
    <fitnessminimum>5</fitnessminimum>
  </improveabovebelow>
  <machinelearning priority="0">
    <autorun enable="$ML"/>
    <update enable='$MLUPDATE'/>
    <threshold>$THRESHOLD</threshold>
    <futuredays>$FUTUREDAYS</futuredays>
    <mlmacd enable='true'>
    </mlmacd>
    <mlrsi enable='true'>
    </mlrsi>
    <mlatr enable='true'>
    </mlatr>
    <mlcci enable='true'>
    </mlcci>
    <mlstoch enable='true'>
    </mlstoch>
    <mlmulti enable='true'>
    </mlmulti>
    <mlindicator enable='true'>
    </mlindicator>
    <predictor enable='true' priority="80">
    </predictor>
  </machinelearning>
  <dataset priority="70">
    <autorun enable="$DATASET"/>
    <update enable='$DATASETUPDATE'/>
    <predictor enable='false'>
    </predictor>
  </dataset>
  <crosstest  priority="40">
    <autorun enable="$CROSSTEST"/>
    <predictor enable='true' priority="50">
    </predictor>
    <market id="nordfund">
      <config>{ "market" : "nordfund", "persisttime" : 30, "findtime" : 7, "evolvetime" : 60, "improvetime" : 150, "startoffset" : 1 }</config>
    </market>
  </crosstest>
  <simulateinvest priority="0">
    <autorun enable="$SIMULATEINVEST"/>
  </simulateinvest>
  <improvesimulateinvest priority="0">
    <autorun enable="$IMPROVESIMULATEINVEST"/>
    <evolutionconfig>{ "generations" : 100, "shutdownhour" : 24 }</evolutionconfig>
  </improvesimulateinvest>
  <improveautosimulateinvest priority="0">
    <autorun enable="$IMPROVEAUTOSIMULATEINVEST"/>
    <evolutionconfig>{ "generations" : 100, "shutdownhour" : 24 }</evolutionconfig>
  </improveautosimulateinvest>
  <filter priority="90">
    <autorun enable="true"/>
    <recommender enable='true'/>
    <mlmacd enable='true'>
    </mlmacd>
    <mlrsi enable='true'>
    </mlrsi>
    <mlatr enable='true'>
    </mlatr>
    <mlcci enable='true'>
    </mlcci>
    <mlstoch enable='true'>
    </mlstoch>
    <mlmulti enable='true'>
    </mlmulti>
    <mlindicator enable='true'>
    </mlindicator>
    <predictor enable='false'>
    </predictor>
  </filter>
  <singlemarket>
    <loops>5</loops>
  </singlemarket>
  <verification>
    <loops>5</loops>
    <days>10</days>
    <improveprofit enable='false'/>
    <!--recommender>
      <topbottom>10</topbottom>
    </recommender-->
  </verification>

  <!-- icore, place for marketlist, plus isim -->
  $MARKETS
</config>
